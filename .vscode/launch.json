{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Django Backend",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/octofit-tracker/backend/octofit_tracker/manage.py",
      "cwd": "${workspaceFolder}/octofit-tracker/backend/octofit_tracker",
      "args": ["runserver", "0.0.0.0:8000"],
      "django": true,
      "justMyCode": true,
      "python": "${workspaceFolder}/octofit-tracker/backend/venv/bin/python"
    },
    {
      "name": "Launch React Frontend",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/octofit-tracker/frontend/node_modules/react-scripts/scripts/start.js",
      "cwd": "${workspaceFolder}/octofit-tracker/frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["start"],
      "env": {
        "REACT_APP_CODESPACE_NAME": "${env:CODESPACE_NAME}"
      }
    }
  ]
}